---
import BaseLayout from '@/layouts/BaseLayout.astro';

const photos = [
	{ src: "/images/gallery/0ca1136a-0f5a-4223-8810-55792d4fb669_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/1feffd94-6b61-400c-977f-c5943b52fcac_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/368e1298-e6fc-4416-992b-a190eed326fc_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/2a92ce90-f400-430d-87c3-cc003020dd16_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/3ce97921-4538-42e0-a7b4-ce21cadb0d87_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/461fef4c-b024-4272-9a29-8926aeaf534e_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/3707e859-ceb8-4644-98a2-55fceb52acc7_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/7030c2b3-6ff9-4eb1-891c-c57545f20977_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/7b507f13-f6d5-49a7-ba9e-09fdc6c9852d_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/8c78b298-d03f-45cf-a9ee-280d6452d511_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/b6beaf4b-ff57-41c2-8a71-6e2109ecec6a_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/82dad4be-1e12-4a34-9a44-0326a3d920c5_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/c3cebf17-3c31-4165-aced-2c4bd490c1a1_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/ccd89fd7-1324-4b5f-ac3f-c9038ebc0fb3_rw_1920.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/f9806845-a205-4f0b-894b-b363882474e8_rw_3840.jpg", alt: "Photography by Victor Thuo" },
	{ src: "/images/gallery/fc1f50c6-0d37-4528-95f9-2ba59475182d_rw_1920.jpg", alt: "Photography by Victor Thuo" },
];
---

<BaseLayout
	title="Photography – Victor Thuo"
	description="Stepping back to keep things in focus. Light, stillness, and everything in between."
	hideCTA
>
	<!-- Page Header -->
	<section class="py-20 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<h1 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100 mb-6">
				Photography
			</h1>
			<p class="text-lg text-silver-500 dark:text-silver-400 font-sans">
				Stepping back to keep things in focus. Light, stillness, and everything in between.
			</p>
		</div>
	</section>

	<!-- Masonry Gallery -->
	<section class="pb-24 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<div class="masonry-gallery" id="gallery">
				{photos.map((photo, index) => (
					<div class="masonry-item cursor-pointer" data-index={index} role="button" tabindex="0" aria-label={`View photo ${index + 1}`}>
						<img
							src={photo.src}
							alt={photo.alt}
							loading="lazy"
							draggable="false"
							class="w-full block pointer-events-none select-none"
						/>
						<div class="absolute inset-0 bg-black/0 hover:bg-black/10 transition-colors duration-300" aria-hidden="true"></div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Lightbox -->
	<div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center" role="dialog" aria-modal="true" aria-label="Photo viewer">
		<div id="lightbox-backdrop" class="absolute inset-0 bg-black/90 backdrop-blur-sm"></div>
		<button id="lightbox-close" class="absolute top-6 right-6 z-10 text-white/70 hover:text-white transition-colors p-2" aria-label="Close lightbox">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
		<button id="lightbox-prev" class="absolute left-4 lg:left-8 z-10 text-white/50 hover:text-white transition-colors p-3" aria-label="Previous photo">
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
			</svg>
		</button>
		<button id="lightbox-next" class="absolute right-4 lg:right-8 z-10 text-white/50 hover:text-white transition-colors p-3" aria-label="Next photo">
			<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
			</svg>
		</button>
		<div class="relative z-10 max-w-[90vw] max-h-[85vh] flex items-center justify-center">
			<img id="lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain select-none" draggable="false" />
		</div>
		<div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10">
			<span id="lightbox-counter" class="label-arch text-white/50"></span>
		</div>
	</div>
</BaseLayout>

<style>
	.masonry-item img {
		-webkit-user-drag: none;
		-khtml-user-drag: none;
		-moz-user-drag: none;
		-o-user-drag: none;
		user-drag: none;
		-webkit-touch-callout: none;
	}
</style>

<script>
	function initPhotography() {
		const gallery = document.getElementById('gallery');
		const lightbox = document.getElementById('lightbox');
		const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
		const lightboxCounter = document.getElementById('lightbox-counter');
		const closeBtn = document.getElementById('lightbox-close');
		const prevBtn = document.getElementById('lightbox-prev');
		const nextBtn = document.getElementById('lightbox-next');
		const backdrop = document.getElementById('lightbox-backdrop');

		if (!gallery || !lightbox || !lightboxImg) return;

		const items = gallery.querySelectorAll('.masonry-item');
		const photos: { src: string; alt: string }[] = [];
		items.forEach((item) => {
			const img = item.querySelector('img');
			if (img) photos.push({ src: img.src, alt: img.alt });
		});

		let currentIndex = 0;

		function openLightbox(index: number) {
			currentIndex = index;
			updateLightbox();
			lightbox!.classList.remove('hidden');
			lightbox!.classList.add('flex');
			document.body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			lightbox!.classList.add('hidden');
			lightbox!.classList.remove('flex');
			document.body.style.overflow = '';
		}

		function updateLightbox() {
			const photo = photos[currentIndex];
			if (!photo || !lightboxImg) return;
			lightboxImg.style.opacity = '0';
			lightboxImg.src = photo.src;
			lightboxImg.alt = photo.alt;
			lightboxImg.onload = () => {
				lightboxImg.style.transition = 'opacity 0.2s ease';
				lightboxImg.style.opacity = '1';
			};
			if (lightboxCounter) {
				lightboxCounter.textContent = `${currentIndex + 1} / ${photos.length}`;
			}
		}

		function navigate(direction: number) {
			currentIndex = (currentIndex + direction + photos.length) % photos.length;
			updateLightbox();
		}

		// Gallery click/keyboard handlers
		items.forEach((item) => {
			item.addEventListener('click', () => {
				const index = parseInt(item.getAttribute('data-index') || '0');
				openLightbox(index);
			});
			item.addEventListener('keydown', (e) => {
				if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
					e.preventDefault();
					const index = parseInt(item.getAttribute('data-index') || '0');
					openLightbox(index);
				}
			});
		});

		// Lightbox controls
		closeBtn?.addEventListener('click', closeLightbox);
		backdrop?.addEventListener('click', closeLightbox);
		prevBtn?.addEventListener('click', () => navigate(-1));
		nextBtn?.addEventListener('click', () => navigate(1));

		// Keyboard navigation
		document.addEventListener('keydown', (e) => {
			if (lightbox!.classList.contains('hidden')) return;
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowLeft') navigate(-1);
			if (e.key === 'ArrowRight') navigate(1);
		});

		// Image protection
		gallery.addEventListener('contextmenu', (e) => {
			if (e.target instanceof HTMLImageElement || e.target instanceof HTMLDivElement) {
				e.preventDefault();
			}
		});
		gallery.addEventListener('dragstart', (e) => {
			e.preventDefault();
		});
		lightbox.addEventListener('contextmenu', (e) => {
			e.preventDefault();
		});
	}

	document.addEventListener('astro:page-load', initPhotography);
</script>
