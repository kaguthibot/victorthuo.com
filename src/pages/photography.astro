---
import BaseLayout from '@/layouts/BaseLayout.astro';

const photos = [
	{ src: "/images/gallery/0ca1136a-0f5a-4223-8810-55792d4fb669_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:col-span-2 md:row-span-2" },
	{ src: "/images/gallery/1feffd94-6b61-400c-977f-c5943b52fcac_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/368e1298-e6fc-4416-992b-a190eed326fc_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/2a92ce90-f400-430d-87c3-cc003020dd16_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:row-span-2" },
	{ src: "/images/gallery/3ce97921-4538-42e0-a7b4-ce21cadb0d87_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/461fef4c-b024-4272-9a29-8926aeaf534e_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/3707e859-ceb8-4644-98a2-55fceb52acc7_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:col-span-2" },
	{ src: "/images/gallery/7030c2b3-6ff9-4eb1-891c-c57545f20977_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/7b507f13-f6d5-49a7-ba9e-09fdc6c9852d_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:row-span-2" },
	{ src: "/images/gallery/8c78b298-d03f-45cf-a9ee-280d6452d511_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/b6beaf4b-ff57-41c2-8a71-6e2109ecec6a_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/82dad4be-1e12-4a34-9a44-0326a3d920c5_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:col-span-2" },
	{ src: "/images/gallery/c3cebf17-3c31-4165-aced-2c4bd490c1a1_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/ccd89fd7-1324-4b5f-ac3f-c9038ebc0fb3_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
	{ src: "/images/gallery/f9806845-a205-4f0b-894b-b363882474e8_rw_3840.jpg", alt: "Photography by Victor Thuo", span: "md:col-span-2 md:row-span-2" },
	{ src: "/images/gallery/fc1f50c6-0d37-4528-95f9-2ba59475182d_rw_1920.jpg", alt: "Photography by Victor Thuo", span: "" },
];
---

<BaseLayout
	title="Photography – Victor Thuo"
	description="Stepping back to keep things in focus. Light, stillness, and everything in between."
>
	<!-- Page Header -->
	<section class="py-20 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<h1 class="text-5xl lg:text-6xl font-display font-light text-silver-900 dark:text-silver-100 mb-6">
				Photography
			</h1>
			<p class="text-lg text-silver-400 font-sans max-w-2xl" style="font-weight: 300;">
				Stepping back to keep things in focus. Light, stillness, and everything in between.
			</p>
		</div>
	</section>

	<!-- Masonry Grid -->
	<section class="pb-24 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 auto-rows-[200px] gap-4" id="gallery">
				{photos.map((photo) => (
					<div class={`gallery-item relative rounded-sm overflow-hidden bg-silver-100 dark:bg-silver-900 ${photo.span}`}>
						<img
							src={photo.src}
							alt={photo.alt}
							loading="lazy"
							draggable="false"
							class="w-full h-full object-cover pointer-events-none select-none"
						/>
						<div class="absolute inset-0" aria-hidden="true"></div>
					</div>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.gallery-item img {
		-webkit-user-drag: none;
		-khtml-user-drag: none;
		-moz-user-drag: none;
		-o-user-drag: none;
		user-drag: none;
		-webkit-touch-callout: none;
	}
</style>

<script>
	const gallery = document.getElementById('gallery');
	if (gallery) {
		gallery.addEventListener('contextmenu', (e) => {
			if (e.target instanceof HTMLImageElement || e.target instanceof HTMLDivElement) {
				e.preventDefault();
			}
		});
		gallery.addEventListener('dragstart', (e) => {
			e.preventDefault();
		});
	}
</script>
