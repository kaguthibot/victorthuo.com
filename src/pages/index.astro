---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudyCard from '@/components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const featuredWork = allWork
	.filter((entry) => entry.data.featured === true)
	.sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
	.slice(0, 3);

const heroSubText = "From AI platforms adopted by thousands to enterprise tools that people actually want to use — design rigor, technical clarity, and business thinking for complex problems.";
const povText = "Design has a business fluency problem. Design craft is the answer, not the casualty.";
---

<BaseLayout title="Victor Thuo – Experience Design & AI Product Strategy" description="I design the products, platforms, and strategies that turn ambitious ideas into measurable outcomes. Design rigor, technical clarity, and business thinking for complex problems.">
	<!-- Hero — full viewport, oversized name, dot grid bg -->
	<section class="min-h-[92vh] flex items-end pb-20 lg:pb-28 px-8 bg-dot-grid bg-dot-grid-fade glow-accent relative">
		<div class="max-w-6xl mx-auto w-full relative z-10">
			<!-- Oversized name — cinematic scale -->
			<div class="mb-12 lg:mb-16">
				<p class="label-arch text-clay mb-8 hero-stagger" style="--stagger: 0">Experience Design & AI Product Strategy</p>
				<h1 class="hero-headline text-silver-950 dark:text-silver-100 hero-stagger" style="--stagger: 1">
					Good design makes
				</h1>
				<h1 class="hero-headline text-silver-950 dark:text-silver-100 hero-stagger" style="--stagger: 2">
					value <span class="text-clay">tangible,</span>
				</h1>
				<h1 class="hero-headline text-silver-950 dark:text-silver-100 hero-stagger italic" style="--stagger: 3">
					Tastefully
				</h1>
			</div>

			<!-- Bottom bar — descriptor + CTA -->
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-end">
				<div class="lg:col-span-7">
					<p class="font-display italic text-lg lg:text-xl text-silver-400 dark:text-silver-500 max-w-lg leading-relaxed hero-stagger" style="--stagger: 4">
						{povText}
					</p>
				</div>
				<div class="lg:col-span-5 lg:border-l lg:border-silver-200 dark:lg:border-silver-800 lg:pl-8">
					<p class="text-silver-500 dark:text-silver-400 leading-relaxed mb-6 text-sm hero-stagger" style="--stagger: 5">
						{heroSubText}
					</p>
					<a href="/work" class="group inline-flex items-center gap-4 text-silver-900 dark:text-silver-100 font-medium text-sm hero-stagger" style="--stagger: 6">
						View selected work
						<span class="w-8 h-px bg-clay inline-block transition-all duration-300 group-hover:w-14"></span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Capabilities — asymmetric grid -->
	<section class="py-28">
		<div class="max-w-5xl mx-auto px-8">
			<div class="mb-20 reveal">
				<h2 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100">Capabilities</h2>
			</div>

			<div class="grid grid-cols-12 gap-6 stagger">
				<div class="col-span-12 md:col-span-7 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Experience Design</h3>
						<span class="font-display italic text-clay text-lg">7,800+ users</span>
					</div>
					<p class="text-silver-500 dark:text-silver-400 leading-relaxed">
						Complex tools don't have to feel complex. I design enterprise products, from AI platforms to developer portals, that are clear on day one and powerful on day hundred.
					</p>
				</div>

				<div class="col-span-12 md:col-span-5 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Digital Strategy</h3>
						<span class="font-display italic text-clay text-lg">5X growth</span>
					</div>
					<p class="text-silver-500 dark:text-silver-400 leading-relaxed">
						Strategy without execution is a slide deck. I connect product vision to engineering reality and business outcomes, then build the roadmap to get there.
					</p>
				</div>

				<div class="col-span-12 md:col-span-5 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Behavior Change</h3>
						<span class="font-display italic text-clay text-lg">2X adoption</span>
					</div>
					<p class="text-silver-500 dark:text-silver-400 leading-relaxed">
						Great design gets ignored if it asks people to change without giving them a reason. I study how people actually make decisions and design around it. Reducing friction, not adding training.
					</p>
				</div>

				<div class="col-span-12 md:col-span-7 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Product Adoption</h3>
						<span class="font-display italic text-clay text-lg">31K migrated</span>
					</div>
					<p class="text-silver-500 dark:text-silver-400 leading-relaxed">
						A launch is just the beginning. I build the onboarding, rollout, and support that turn a pilot into a company standard. 90% cost reductions realized. 89% audience reached.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- POV — word-by-word scroll reveal -->
	<section class="py-24 lg:py-32">
		<div class="max-w-4xl mx-auto px-8">
			<p class="word-reveal text-3xl lg:text-4xl font-display text-silver-900 dark:text-silver-100 leading-snug" id="pov-reveal">
				{povText.split(' ').map((word) => (
					<span class="word inline-block mr-[0.3em]">{word}</span>
				))}
			</p>
		</div>
	</section>

	<!-- Featured Work -->
	<section class="py-32">
		<div class="max-w-5xl mx-auto px-8">
			<div class="mb-20 reveal">
				<h2 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100">Selected work</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-16 stagger mb-12">
				{featuredWork.map((work) => (
					<CaseStudyCard work={work} />
				))}
			</div>
			<div class="text-center">
				<a href="/work" class="group inline-flex items-center gap-4 text-silver-800 dark:text-silver-200 font-medium text-sm">
					View all work
					<span class="w-8 h-px bg-clay inline-block transition-all duration-300 group-hover:w-14"></span>
				</a>
			</div>
		</div>
	</section>

</BaseLayout>
