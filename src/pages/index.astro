---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudyCard from '@/components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const featuredWork = allWork
	.filter((entry) => entry.data.featured === true)
	.sort((a, b) => (a.data.order || 999) - (b.data.order || 999))
	.slice(0, 3);

const heroSubText = "From AI platforms adopted by thousands to enterprise tools that people actually want to use. I bring design rigor, technical clarity, and business thinking to complex problems.";
const povText = "Design has a business fluency problem. Design craft is the answer, not the casualty.";
---

<BaseLayout title="Victor Thuo – Experience Design & AI Product Strategy" description="I design the products, platforms, and strategies that turn ambitious ideas into measurable outcomes. Design rigor, technical clarity, and business thinking for complex problems.">
	<!-- Hero — centered -->
	<section class="min-h-[88vh] flex items-center justify-center px-8">
		<div class="max-w-3xl text-center reveal">
			<p class="label-arch text-clay mb-8">Experience Design & AI Product Strategy</p>
			<h1 class="text-5xl lg:text-7xl font-display text-silver-950 dark:text-silver-100 leading-[1.08] mb-10">
				Good design makes value tangible, Tastefully
			</h1>
			<p class="text-lg text-silver-400 leading-relaxed mb-12 max-w-xl mx-auto word-reveal" style="font-weight: 300;">
				{heroSubText.split(/\s+/).map((word, i) => (
					<span class="word" style={`transition-delay: ${i * 30}ms`}>{word} </span>
				))}
			</p>
			<a href="/work" class="link-subtle text-silver-800 dark:text-silver-200 font-medium text-sm inline-flex items-center gap-3">
				View work
				<span class="w-8 h-px bg-silver-300 inline-block"></span>
			</a>
		</div>
	</section>

	<!-- POV — contained, no full-width color -->
	<section class="py-20 reveal">
		<div class="max-w-2xl mx-auto px-8 text-center">
			<div class="w-8 h-px bg-clay mx-auto mb-8"></div>
			<p class="text-xl font-display italic text-silver-500 dark:text-silver-400 leading-relaxed word-reveal" style="font-weight: 400;">
				{povText.split(/\s+/).map((word, i) => (
					<span class="word" style={`transition-delay: ${i * 40}ms`}>{word} </span>
				))}
			</p>
			<div class="w-8 h-px bg-clay mx-auto mt-8"></div>
		</div>
	</section>

	<!-- Capabilities — asymmetric grid -->
	<section class="py-24">
		<div class="max-w-5xl mx-auto px-8">
			<div class="text-center mb-20 reveal">
				<p class="label-arch text-silver-400 mb-4">What I do</p>
				<h2 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100">Capabilities</h2>
			</div>

			<div class="grid grid-cols-12 gap-6 stagger">
				<div class="col-span-12 md:col-span-7 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Experience Design</h3>
						<span class="text-xs font-mono text-silver-300 tracking-wide">01</span>
					</div>
					<p class="text-silver-400 leading-relaxed" style="font-weight: 300;">
						Complex tools don't have to feel complex. I design enterprise products, from AI platforms to developer portals, that are clear on day one and powerful on day hundred. 7,800+ users adopted. 2X productivity gains delivered.
					</p>
				</div>

				<div class="col-span-12 md:col-span-5 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Digital Strategy</h3>
						<span class="text-xs font-mono text-silver-300 tracking-wide">02</span>
					</div>
					<p class="text-silver-400 leading-relaxed" style="font-weight: 300;">
						Strategy without execution is a slide deck. I connect product vision to engineering reality and business outcomes, then build the roadmap to get there.
					</p>
				</div>

				<div class="col-span-12 md:col-span-5 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Behavior Change</h3>
						<span class="text-xs font-mono text-silver-300 tracking-wide">03</span>
					</div>
					<p class="text-silver-400 leading-relaxed" style="font-weight: 300;">
						Great design gets ignored if it asks people to change without giving them a reason. I study how people actually make decisions and design around it. Reducing friction, not adding training.
					</p>
				</div>

				<div class="col-span-12 md:col-span-7 py-10 px-8 border border-silver-150 dark:border-silver-800 rounded-sm slide-hover group">
					<div class="flex items-baseline justify-between mb-4">
						<h3 class="text-2xl font-display text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">Product Adoption</h3>
						<span class="text-xs font-mono text-silver-300 tracking-wide">04</span>
					</div>
					<p class="text-silver-400 leading-relaxed" style="font-weight: 300;">
						A launch is just the beginning. I build the onboarding, rollout, and support that turn a pilot into a company standard. 31,000 users migrated. 90% cost reductions realized. 89% audience reached.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Featured Work -->
	<section class="py-32">
		<div class="max-w-5xl mx-auto px-8">
			<div class="text-center mb-20 reveal">
				<p class="label-arch text-silver-400 mb-4">Case studies</p>
				<h2 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100">Selected work</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-16 stagger mb-12">
				{featuredWork.map((work) => (
					<CaseStudyCard work={work} />
				))}
			</div>
			<div class="text-center">
				<a href="/work" class="link-subtle text-silver-800 dark:text-silver-200 font-medium text-sm inline-flex items-center gap-3">
					View all work
					<span class="w-8 h-px bg-silver-300 inline-block"></span>
				</a>
			</div>
		</div>
	</section>

</BaseLayout>
