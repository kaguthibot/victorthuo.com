---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PerspectiveCard from '@/components/PerspectiveCard.astro';
import FeaturedPerspectiveCard from '@/components/FeaturedPerspectiveCard.astro';
import { getCollection } from 'astro:content';

const allPerspectives = await getCollection('perspectives');
const perspectives = allPerspectives
	.filter((entry) => !entry.data.draft)
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const [featured, ...rest] = perspectives;

const breadcrumbs = [
	{ name: 'Home', url: 'https://victorthuo.com' },
	{ name: 'Perspectives', url: 'https://victorthuo.com/perspectives' },
];
---

<BaseLayout
	title="Perspectives – Victor Thuo"
	description="Thoughts on design leadership, behavioral strategy, and building products people actually use."
	breadcrumbs={breadcrumbs}
>
	<!-- Page Header -->
	<section class="py-20 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<h1 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100 mb-6">
				Perspectives
			</h1>
			<p class="text-lg text-silver-500 dark:text-silver-400 font-sans max-w-2xl">
				Thoughts on design leadership, behavioral strategy, and building products people actually use.
			</p>
		</div>
	</section>

	<!-- Featured Article -->
	{featured && (
		<section class="pb-12 reveal">
			<div class="max-w-6xl mx-auto px-6">
				<FeaturedPerspectiveCard perspective={featured} />
			</div>
		</section>
	)}

	<!-- Remaining Articles -->
	{rest.length > 0 && (
		<section class="pb-24 reveal">
			<div class="max-w-6xl mx-auto px-6">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{rest.map((perspective) => (
						<PerspectiveCard perspective={perspective} />
					))}
				</div>
			</div>
		</section>
	)}
</BaseLayout>
