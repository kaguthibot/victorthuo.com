---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudyCard from '@/components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');
const sortedWork = allWork.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));

const categories = ['All', 'Experience Design', 'Digital Strategy', 'Behavior Change'];

const breadcrumbs = [
	{ name: 'Home', url: 'https://victorthuo.com' },
	{ name: 'Work', url: 'https://victorthuo.com/work' },
];
---

<BaseLayout
	title="Work – Victor Thuo"
	description="Case studies in experience design, digital strategy, and behavior change."
	breadcrumbs={breadcrumbs}
>
	<!-- Page Header -->
	<section class="py-20 reveal">
		<div class="max-w-6xl mx-auto px-6">
			<h1 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100 mb-6">
				Work
			</h1>
			<p class="text-lg text-silver-500 dark:text-silver-400 font-sans max-w-2xl">
				Case studies in experience design, digital strategy, and behavior change.
			</p>
			<p class="label-arch text-silver-300 dark:text-silver-500 mt-4">{sortedWork.length} case studies</p>
		</div>
	</section>

	<!-- Category Filters + View Toggle -->
	<section class="pb-12 reveal">
		<div class="max-w-6xl mx-auto px-6 flex flex-wrap items-center justify-between gap-4">
			<div class="flex flex-wrap gap-3">
				{categories.map((category) => (
					<button
						data-category={category}
						class={`filter-btn px-4 py-2 text-sm font-sans font-medium rounded-sm transition-all ${
							category === 'All'
								? 'bg-silver-900 dark:bg-silver-100 text-white dark:text-silver-900'
								: 'bg-silver-100 dark:bg-silver-900 text-silver-900 dark:text-silver-100 hover:bg-silver-200 dark:hover:bg-silver-800'
						}`}
					>
						{category}
					</button>
				))}
			</div>
			<div class="flex items-center gap-1">
				<button
					id="view-grid"
					class="view-toggle p-2 text-silver-900 dark:text-silver-100 transition-colors"
					aria-label="Grid view"
					aria-pressed="true"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
						<rect x="3" y="3" width="7" height="7" rx="1" />
						<rect x="14" y="3" width="7" height="7" rx="1" />
						<rect x="3" y="14" width="7" height="7" rx="1" />
						<rect x="14" y="14" width="7" height="7" rx="1" />
					</svg>
				</button>
				<button
					id="view-list"
					class="view-toggle p-2 text-silver-400 transition-colors"
					aria-label="List view"
					aria-pressed="false"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
						<path stroke-linecap="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
					</svg>
				</button>
			</div>
		</div>
	</section>

	<!-- Work Grid -->
	<section class="pb-24 reveal" id="workGridSection">
		<div class="max-w-6xl mx-auto px-6">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16" id="workGrid">
				{sortedWork.map((work) => (
					<div data-category={work.data.category}>
						<CaseStudyCard work={work} />
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Work List -->
	<section class="pb-24 hidden" id="workListSection">
		<div class="max-w-6xl mx-auto px-6">
			<div class="border-t border-silver-150 dark:border-silver-800">
				{sortedWork.map((work) => (
					<a
						href={`/work/${work.slug}`}
						data-category={work.data.category}
						class="group flex items-center justify-between py-5 px-4 border-b border-silver-150 dark:border-silver-800 slide-hover transition-colors"
					>
						<span class="font-display text-lg text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors duration-300">
							{work.data.title}
						</span>
						<div class="flex items-center gap-8 shrink-0 ml-4">
							<span class="label-arch text-silver-400 hidden sm:inline">
								{work.data.category}
							</span>
							<span class="label-arch text-silver-300 dark:text-silver-500 tabular-nums w-10 text-right">
								{work.data.year || ''}
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const gridCards = document.querySelectorAll<HTMLElement>('#workGrid [data-category]');
	const listRows = document.querySelectorAll<HTMLElement>('#workListSection [data-category]');

	const activeClasses = ['bg-silver-900', 'dark:bg-silver-100', 'text-white', 'dark:text-silver-900'];
	const inactiveClasses = ['bg-silver-100', 'dark:bg-silver-900', 'text-silver-900', 'dark:text-silver-100'];

	// Category filtering — targets both grid and list
	buttons.forEach((button) => {
		button.addEventListener('click', () => {
			const category = button.getAttribute('data-category');

			buttons.forEach((btn) => {
				btn.classList.remove(...activeClasses);
				btn.classList.add(...inactiveClasses);
			});
			button.classList.remove(...inactiveClasses);
			button.classList.add(...activeClasses);

			[...gridCards, ...listRows].forEach((item) => {
				const itemCategory = item.getAttribute('data-category');
				if (category === 'All' || itemCategory === category) {
					item.classList.remove('hidden');
				} else {
					item.classList.add('hidden');
				}
			});
		});
	});

	// View toggle
	const gridBtn = document.getElementById('view-grid');
	const listBtn = document.getElementById('view-list');
	const gridSection = document.getElementById('workGridSection');
	const listSection = document.getElementById('workListSection');

	function setView(view: string) {
		if (!gridSection || !listSection || !gridBtn || !listBtn) return;
		if (view === 'grid') {
			gridSection.classList.remove('hidden');
			listSection.classList.add('hidden');
			gridBtn.className = 'view-toggle p-2 text-silver-900 dark:text-silver-100 transition-colors';
			listBtn.className = 'view-toggle p-2 text-silver-400 transition-colors';
			gridBtn.setAttribute('aria-pressed', 'true');
			listBtn.setAttribute('aria-pressed', 'false');
		} else {
			gridSection.classList.add('hidden');
			listSection.classList.remove('hidden');
			listBtn.className = 'view-toggle p-2 text-silver-900 dark:text-silver-100 transition-colors';
			gridBtn.className = 'view-toggle p-2 text-silver-400 transition-colors';
			listBtn.setAttribute('aria-pressed', 'true');
			gridBtn.setAttribute('aria-pressed', 'false');
		}
	}

	gridBtn?.addEventListener('click', () => setView('grid'));
	listBtn?.addEventListener('click', () => setView('list'));
</script>
