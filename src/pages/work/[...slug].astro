---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
	const allWork = await getCollection('work');
	return allWork.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Get all work sorted by order to find next/prev project
const allWork = await getCollection('work');
const sortedWork = allWork.sort((a, b) => (a.data.order || 999) - (b.data.order || 999));
const currentIndex = sortedWork.findIndex((w) => w.slug === entry.slug);
const nextProject = currentIndex < sortedWork.length - 1 ? sortedWork[currentIndex + 1] : sortedWork[0];
const prevProject = currentIndex > 0 ? sortedWork[currentIndex - 1] : null;

const breadcrumbs = [
	{ name: 'Home', url: 'https://victorthuo.com' },
	{ name: 'Work', url: 'https://victorthuo.com/work' },
	{ name: entry.data.title, url: `https://victorthuo.com/work/${entry.slug}` },
];
---

<BaseLayout title={entry.data.title} description={entry.data.summary} breadcrumbs={breadcrumbs} hideCTA>
	<!-- Scroll Progress Bar -->
	<div id="scroll-progress" class="fixed top-0 left-0 h-[2px] bg-clay z-[60]" style="width: 0%;"></div>

	<article>
		<!-- Back Link -->
		<div class="py-8 reveal">
			<div class="max-w-4xl mx-auto px-6">
				<a href="/work" class="group inline-flex items-center gap-2 text-silver-500 dark:text-silver-400 hover:text-silver-800 dark:hover:text-silver-200 font-sans transition-colors text-sm">
					<span class="transition-transform duration-200 group-hover:-translate-x-1">←</span>
					Work
				</a>
			</div>
		</div>

		<!-- Header -->
		<header class="py-12 reveal">
			<div class="max-w-4xl mx-auto px-6">
				<span class="tag-clay mb-4">{entry.data.category}</span>

				<h1 class="text-4xl lg:text-5xl font-display text-silver-900 dark:text-silver-100 mb-6 leading-tight">
					{entry.data.title}
				</h1>

				<p class="text-lg text-silver-500 dark:text-silver-400 font-sans leading-relaxed max-w-2xl">
					{entry.data.summary}
				</p>

				{/* Metadata row */}
				{(entry.data.role || entry.data.timeline || entry.data.year) && (
					<div class="flex flex-wrap gap-x-8 gap-y-3 mt-8 pt-6 border-t border-silver-150 dark:border-silver-800">
						{entry.data.role && (
							<div>
								<p class="label-arch text-silver-400 mb-1">Role</p>
								<p class="text-sm text-silver-700 dark:text-silver-200 font-medium">{entry.data.role}</p>
							</div>
						)}
						{entry.data.timeline && (
							<div>
								<p class="label-arch text-silver-400 mb-1">Timeline</p>
								<p class="text-sm text-silver-700 dark:text-silver-200 font-medium">{entry.data.timeline}</p>
							</div>
						)}
						{entry.data.year && (
							<div>
								<p class="label-arch text-silver-400 mb-1">Year</p>
								<p class="text-sm text-silver-700 dark:text-silver-200 font-medium">{entry.data.year}</p>
							</div>
						)}
						{entry.data.team && (
							<div>
								<p class="label-arch text-silver-400 mb-1">Team</p>
								<p class="text-sm text-silver-700 dark:text-silver-200 font-medium">{entry.data.team}</p>
							</div>
						)}
					</div>
				)}
			</div>
		</header>

		<!-- Content -->
		<section class="py-16 reveal">
			<div class="max-w-4xl mx-auto px-6 prose prose-lg">
				<Content />

				{entry.data.metrics && entry.data.metrics.length > 0 && (
					<div class="mt-16 pt-8 border-t border-silver-200 dark:border-silver-800">
						<p class="label-arch text-silver-400 mb-6" style="color: #a0a0a5;">Key results</p>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-6 !pl-0">
							{entry.data.metrics.map((metric: string) => (
								<div class="flex items-baseline gap-3">
									<span class="w-1.5 h-1.5 rounded-full bg-clay shrink-0 relative top-[0.35rem]"></span>
									<span class="text-silver-700 dark:text-silver-200 font-medium" style="font-size: 0.95rem;">{metric}</span>
								</div>
							))}
						</div>
					</div>
				)}
			</div>
		</section>

		<!-- Prev / Next Navigation -->
		<section class="py-20 border-t border-silver-200 dark:border-silver-800 reveal">
			<div class="max-w-4xl mx-auto px-6">
				<div class="flex items-start justify-between gap-8">
					{prevProject ? (
						<a href={`/work/${prevProject.slug}`} class="group flex-1">
							<p class="label-arch text-silver-400 mb-2">Previous</p>
							<p class="font-display text-lg text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors">
								{prevProject.data.title}
							</p>
						</a>
					) : <div class="flex-1" />}

					<a href={`/work/${nextProject.slug}`} class="group flex-1 text-right">
						<p class="label-arch text-silver-400 mb-2">Next</p>
						<p class="font-display text-lg text-silver-900 dark:text-silver-100 group-hover:text-clay transition-colors">
							{nextProject.data.title}
						</p>
					</a>
				</div>
			</div>
		</section>
	</article>

	<script>
		function initScrollProgress() {
			const bar = document.getElementById('scroll-progress');
			if (!bar) return;
			function update() {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
				bar.style.width = progress + '%';
			}
			let ticking = false;
			window.addEventListener('scroll', () => {
				if (!ticking) {
					requestAnimationFrame(() => { update(); ticking = false; });
					ticking = true;
				}
			}, { passive: true });
			update();
		}
		document.addEventListener('astro:page-load', initScrollProgress);
	</script>
</BaseLayout>
