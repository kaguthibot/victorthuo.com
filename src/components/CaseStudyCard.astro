---
interface Props {
  work: {
    slug: string;
    data: {
      title: string;
      category?: string;
      summary: string;
      image?: string;
      metrics?: string[];
      featured?: boolean;
    };
  };
}

const { work } = Astro.props;
const { title, category = 'default', summary, image, metrics, featured = false } = work.data;
const slug = work.slug;
const firstMetric = metrics && metrics.length > 0 ? metrics[0] : null;
---

<a href={`/work/${slug}`} class="group block card-tilt" data-tilt>
  <div class="rounded-sm overflow-hidden">
    <div class={`w-full aspect-[4/3] bg-silver-100 dark:bg-silver-900 flex items-center justify-center transition-all duration-500 group-hover:bg-silver-150 dark:group-hover:bg-silver-800 overflow-hidden relative`}>
      {image ? (
        <img
          src={image}
          alt={title}
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700"
        />
      ) : (
        <span class="label-arch text-silver-300">{category}</span>
      )}
      {firstMetric && (
        <span class="absolute bottom-3 left-3 bg-clay/90 dark:bg-clay/80 text-white text-xs font-medium px-2.5 py-1 rounded-sm backdrop-blur-sm">
          {firstMetric}
        </span>
      )}
    </div>
    <div class="pt-5">
      <span class={`mb-3 ${category.toLowerCase() !== 'default' ? 'tag-clay' : 'tag'}`}>
        {category}
      </span>
      <h3 class="text-lg font-display text-silver-900 dark:text-silver-100 mb-2 group-hover:text-clay transition-colors duration-300">
        {title}
      </h3>
      <p class="text-sm text-silver-500 dark:text-silver-400 leading-relaxed line-clamp-2">
        {summary}
      </p>
    </div>
  </div>
</a>
