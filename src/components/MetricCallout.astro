---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center py-8 px-6 bg-silver-50 dark:bg-silver-950 rounded-sm border border-silver-200 dark:border-silver-800">
  <div class="text-4xl font-bold text-clay mb-2">
    {value}
  </div>
  <div class="text-sm text-silver-500 dark:text-silver-400 font-medium">
    {label}
  </div>
</div>
